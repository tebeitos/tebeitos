---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import SeccionKiosko from '../../components/SeccionKiosko.astro';
import { getCollection } from 'astro:content';

const articulos = await getCollection('blog');
const ordenados = articulos.sort((a, b) => b.data.fecha.valueOf() - a.data.fecha.valueOf());
---

<Base
  title="Blog — Del cuaderno de Tebeitos"
  description="Guías, recomendaciones y artículos sobre cómics, cromos y juguetes retro. El cuaderno de Tebeitos."
  breadcrumbs={[{ label: 'Blog', href: '/blog/' }]}
>
  <Header slot="header" />

  <div class="pt-24">
    <SeccionKiosko titulo="El cuadernillo de Tebeitos" fondo="crema">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {ordenados.map(articulo => {
          const fecha = new Intl.DateTimeFormat('es-ES', {
            day: 'numeric', month: 'long', year: 'numeric'
          }).format(articulo.data.fecha);

          return (
            <article class="comic-border bg-crema flex flex-col group hover:shadow-comic-lg transition-shadow duration-150">
              {articulo.data.imagen ? (
                <div class="h-44 overflow-hidden border-b-3 border-negro bg-crema relative">
                  <img
                    src={articulo.data.imagen}
                    alt={articulo.data.title}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-200"
                    loading="lazy"
                  />
                </div>
              ) : (
                <div class="h-44 bg-trama/50 border-b-3 border-negro flex items-center justify-center">
                  <span class="text-4xl">📝</span>
                </div>
              )}
              <div class="p-5 flex flex-col gap-3 flex-1">
                <span class="font-fredoka text-xs text-rojo uppercase tracking-wide">{articulo.data.categoria}</span>
                <h2 class="font-bangers text-xl tracking-bangers text-negro leading-tight group-hover:text-rojo transition-colors">
                  <a href={`/blog/${articulo.slug}/`}>{articulo.data.title}</a>
                </h2>
                <p class="font-nunito text-sm text-negro/70 line-clamp-3 flex-1">{articulo.data.descripcion}</p>
                <div class="flex items-center justify-between mt-auto pt-3 border-t-2 border-negro/10">
                  <span class="font-fredoka text-xs text-trama">{fecha}</span>
                  <a href={`/blog/${articulo.slug}/`} class="font-fredoka text-xs text-rojo hover:underline">
                    Leer →
                  </a>
                </div>
              </div>
            </article>
          );
        })}
      </div>
    </SeccionKiosko>
  </div>

  <Footer slot="footer" />
</Base>
