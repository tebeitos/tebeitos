---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import SeccionKiosko from '../../components/SeccionKiosko.astro';
import Onomatopeya from '../../components/Onomatopeya.astro';

const juegos = [
  {
    titulo: "Dobble",
    desc: "El juego de rapidez visual y reflejos más divertido. Encuentra el símbolo repetido antes que nadie.",
    marca: "Asmodee",
    edad: "6+",
    precio: 15.99,
    valoracion: 5,
    amazon: "https://www.amazon.es/s?k=dobble+juego&tag=tebeitos-21",
    icono: "👀"
  },
  {
    titulo: "Virus!",
    desc: "El juego de cartas de contagios, órganos y vacunas más adictivo. Rápido, divertido y muy gamberro.",
    marca: "Tranjis Games",
    edad: "8+",
    precio: 14.99,
    valoracion: 5,
    amazon: "https://www.amazon.es/s?k=virus+juego+de+cartas&tag=tebeitos-21",
    icono: "🦠"
  },
  {
    titulo: "Catan Junior",
    desc: "Iníciate en la colonización de la isla de Catan como un intrépido pirata en esta genial versión infantil.",
    marca: "Devir España",
    edad: "6+",
    precio: 29.99,
    valoracion: 5,
    amazon: "https://www.amazon.es/s?k=catan+junior&tag=tebeitos-21",
    icono: "⛵"
  },
  {
    titulo: "Dixit",
    desc: "Usa tu imaginación, empatía y poesía en este deslumbrante juego de adivinar cartas ilustradas.",
    marca: "Libellud",
    edad: "8+",
    precio: 32.99,
    valoracion: 5,
    amazon: "https://www.amazon.es/s?k=dixit+juego&tag=tebeitos-21",
    icono: "🖼️"
  },
  {
    titulo: "Jungle Speed",
    desc: "Atrapa el tótem de madera al vuelo antes que tus rivales cuando las cartas coincidan. ¡Reflejos de acero!",
    marca: "Asmodee",
    edad: "7+",
    precio: 21.99,
    valoracion: 5,
    amazon: "https://www.amazon.es/s?k=jungle+speed&tag=tebeitos-21",
    icono: "🗿"
  },
  {
    titulo: "Exploding Kittens",
    desc: "Una versión gatuna de la ruleta rusa con mucha estrategia, desactivadores y gatos explosivos.",
    marca: "Exploding Kittens",
    edad: "7+",
    precio: 19.99,
    valoracion: 5,
    amazon: "https://www.amazon.es/s?k=exploding+kittens+espanol&tag=tebeitos-21",
    icono: "💥"
  },
  {
    titulo: "Jenga",
    desc: "Retira los bloques de madera uno a uno sin derribar la torre. Un juego clásico de pulso firme.",
    marca: "Hasbro Gaming",
    edad: "6+",
    precio: 18.50,
    valoracion: 5,
    amazon: "https://www.amazon.es/s?k=jenga+clasico&tag=tebeitos-21",
    icono: "🪵"
  },
  {
    titulo: "Parchís y Oca de Madera",
    desc: "El clásico tradicional. Lanza los dados, cómete una y cuenta veinte. Diversión multigeneracional.",
    marca: "Clásico",
    edad: "5+",
    precio: 12.95,
    valoracion: 5,
    amazon: "https://www.amazon.es/s?k=parchis+madera+tradicional&tag=tebeitos-21",
    icono: "🎲"
  }
];
---

<Base
  title="Juegos de Mesa en Familia — El Kiosko de Siempre"
  description="Del parchís al Dobble. Juegos para jugar en familia, en el sofá o de camino a cualquier sitio."
  breadcrumbs={[{ label: 'Juegos de mesa', href: '/juegos-de-mesa/' }]}
>
  <Header slot="header" />

  <!-- Hero -->
  <section class="trama-bg border-b-4 border-negro relative overflow-hidden">
    <div class="absolute top-4 right-8 animate-float" aria-hidden="true">
      <Onomatopeya texto="¡DADOS!" color="mostaza" rotacion={12} />
    </div>
    <div class="absolute bottom-4 left-6 opacity-40" aria-hidden="true">
      <Onomatopeya texto="¡TURNO!" color="rojo" rotacion={-8} />
    </div>

    <div class="contenedor pt-20 pb-12 lg:pt-24 lg:pb-16 relative z-10">
      <div class="inline-flex items-center gap-2 bg-rojo text-hueso font-fredoka text-sm px-4 py-1.5 border-3 border-negro shadow-comic mb-5">
        <span>🎲</span><span>DIVERSIÓN MULTIGENERACIONAL</span>
      </div>

      <h1 class="font-bangers text-5xl lg:text-7xl text-negro tracking-bangers leading-none mb-4"
          style="text-shadow: 3px 3px 0 #E8A01B, 5px 5px 0 #1B1714;">
        Juegos de Mesa
      </h1>
      <p class="font-bangers text-2xl lg:text-3xl text-rojo tracking-bangers mb-6">
        Del parchís al Dobble
      </p>

      <div class="comic-border bg-crema p-6 max-w-3xl">
        <p class="font-fredoka text-xl text-negro leading-relaxed mb-3">
          Juegos para jugar en familia, en el sofá o de camino a cualquier sitio.
        </p>
        <p class="font-nunito text-base text-negro/80 leading-relaxed">
          En Tebeitos creemos que no hay nada mejor que apagar las pantallas, sentarse en la mesa del salón y sacar un tablero o un mazo de cartas. Aquí tienes nuestra selección de juegos que triunfan con niños de todas las edades y también divierten a los mayores.
        </p>
      </div>
    </div>
  </section>

  <!-- Lista de juegos -->
  <SeccionKiosko titulo="Juegos recomendados" fondo="hueso">
    <div class="grid-comics">
      {juegos.map(j => (
        <article class="comic-border bg-crema flex flex-col overflow-hidden group hover:shadow-comic-lg transition-shadow duration-200">
          <!-- Portada / Icono Placeholder -->
          <div class="aspect-[2/3] bg-trama border-b-3 border-negro overflow-hidden relative flex flex-col items-center justify-center">
            <div class="w-full h-full flex flex-col items-center justify-center gap-2 group-hover:bg-mostaza transition-colors duration-200">
              <span class="text-6xl">{j.icono}</span>
              <span class="font-fredoka text-[10px] text-negro/65 text-center px-2">Imagen<br/>próximamente</span>
            </div>
          </div>

          <!-- Info -->
          <div class="p-4 flex flex-col flex-1 gap-3">
            <div class="flex items-center justify-between">
              <span class="font-fredoka text-[10px] px-2 py-0.5 border-2 border-negro bg-terracota text-hueso">
                🎲 JUEGO
              </span>
              <span class="font-fredoka text-xs text-negro/60">
                {j.edad} años
              </span>
            </div>

            <h3 class="font-bangers text-xl text-negro leading-tight tracking-bangers group-hover:text-rojo transition-colors duration-150 line-clamp-2">
              {j.titulo}
            </h3>

            <p class="font-nunito text-xs text-negro/50 font-semibold">{j.marca}</p>
            <p class="font-nunito text-xs text-negro/70 flex-1 leading-normal line-clamp-3">{j.desc}</p>

            <!-- Valoración -->
            <div class="flex gap-1" aria-label={`Valoración: ${j.valoracion} de 5`} role="img">
              {Array.from({ length: 5 }).map((_, i) => (
                <svg
                  width="20" height="20" viewBox="0 0 24 24"
                  class={i < j.valoracion ? 'fill-mostaza' : 'fill-trama/40'}
                  aria-hidden="true"
                >
                  <path d="M12 2C6.48 2 2 5.58 2 10c0 2.54 1.37 4.82 3.5 6.35L4 22l5.5-2.5c.82.15 1.65.5 2.5.5 5.52 0 10-3.58 10-8S17.52 2 12 2z"/>
                </svg>
              ))}
            </div>

            <!-- Precio y botón -->
            <div class="mt-auto flex items-center justify-between gap-2 pt-2 border-t-2 border-negro/10">
              <span class="font-bangers text-xl text-negro tracking-wider">{j.precio.toFixed(2)} €</span>
              <a
                href={j.amazon}
                target="_blank"
                rel="noopener noreferrer nofollow"
                class="font-fredoka text-xs bg-rojo text-hueso px-3 py-2 border-2 border-negro shadow-comic-sm hover:translate-x-[1px] hover:translate-y-[1px] hover:shadow-none transition-all duration-100 flex items-center gap-1"
                aria-label={`Comprar ${j.titulo} en Amazon`}
              >
                🛒 Comprar
              </a>
            </div>
          </div>
        </article>
      ))}
    </div>
  </SeccionKiosko>

  <Footer slot="footer" />
</Base>
