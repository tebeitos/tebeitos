---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import SeccionKiosko from '../../components/SeccionKiosko.astro';
import { getCollection } from 'astro:content';

const juegos = await getCollection('juegos');
// Sort by date
juegos.sort((a, b) => b.data.fecha.getTime() - a.data.fecha.getTime());
---

<Base
  title="Juegos de Mesa en Familia — El Kiosko de Siempre"
  description="Juegos para jugar en familia, en el sofá o de camino a cualquier sitio."
  breadcrumbs={[{ label: 'Juegos de mesa', href: '/juegos-de-mesa/' }]}
>
  <Header slot="header" />

  <!-- Cabecera de Sección -->
  <section class="trama-bg border-b-4 border-negro pt-6 pb-8">
    <div class="contenedor">
      <h1 class="titulo-seccion text-4xl lg:text-5xl mb-4">Juegos de Mesa</h1>
      <div class="flex gap-1 mt-2 mb-6">
        <div class="h-1 w-16 bg-rojo"></div>
        <div class="h-1 flex-1 bg-negro"></div>
      </div>
      <p class="font-fredoka text-lg text-negro/70 max-w-3xl">
        En Tebeitos creemos que no hay nada mejor que apagar las pantallas, sentarse en la mesa del salón y sacar un tablero o un mazo de cartas. Aquí tienes nuestra selección de juegos que triunfan con niños de todas las edades y también divierten a los mayores.
      </p>
    </div>
  </section>

  <SeccionKiosko titulo="" fondo="hueso">
    <div class="grid-comics">
      {juegos.map(j => (
        <article class="comic-border bg-crema flex flex-col overflow-hidden group hover:shadow-comic-lg transition-shadow duration-200">
          <!-- Portada / Icono Placeholder -->
          <a href={`/juegos-de-mesa/${j.slug}/`} class="aspect-[2/3] bg-trama border-b-3 border-negro overflow-hidden relative flex flex-col items-center justify-center">
            {j.data.imagen ? (
              <img
                src={j.data.imagen}
                alt={`Imagen de ${j.data.title}`}
                class="w-full h-full object-contain p-2 bg-white group-hover:scale-105 transition-transform duration-200"
              />
            ) : (
              <div class="w-full h-full flex flex-col items-center justify-center gap-2 group-hover:bg-mostaza transition-colors duration-200">
                <span class="text-6xl">🎲</span>
                <span class="font-fredoka text-[10px] text-negro/65 text-center px-2">Imagen<br/>próximamente</span>
              </div>
            )}
          </a>

          <!-- Info -->
          <div class="p-4 flex flex-col flex-1 gap-3">
            <div class="flex items-center justify-between">
              <span class="font-fredoka text-[10px] px-2 py-0.5 border-2 border-negro bg-terracota text-hueso font-bold">
                🎲 JUEGO
              </span>
              <span class="font-fredoka text-xs text-negro/60 font-semibold">
                {j.data.edad} años
              </span>
            </div>

            <h3 class="font-bangers text-xl text-negro leading-tight tracking-bangers group-hover:text-rojo transition-colors duration-150 line-clamp-2">
              <a href={`/juegos-de-mesa/${j.slug}/`}>
                {j.data.title}
              </a>
            </h3>

            <p class="font-nunito text-xs text-negro/50 font-bold">{j.data.marca}</p>
            <p class="font-nunito text-xs text-negro/70 flex-1 leading-normal line-clamp-3">
              {j.body ? j.body.split('\n').find(line => line.trim().length > 0 && !line.startsWith('#')) : ''}
            </p>

            <!-- Valoración -->
            <div class="flex gap-1" aria-label={`Valoración: ${j.data.valoracion} de 5`} role="img">
              {Array.from({ length: 5 }).map((_, i) => (
                <svg
                  width="20" height="20" viewBox="0 0 24 24"
                  class={i < j.data.valoracion ? 'fill-mostaza' : 'fill-trama/40'}
                  aria-hidden="true"
                >
                  <path d="M12 2C6.48 2 2 5.58 2 10c0 2.54 1.37 4.82 3.5 6.35L4 22l5.5-2.5c.82.15 1.65.5 2.5.5 5.52 0 10-3.58 10-8S17.52 2 12 2z"/>
                </svg>
              ))}
            </div>

            <!-- Precio y botón -->
            <div class="mt-auto flex items-center justify-between gap-2 pt-2 border-t-2 border-negro/10">
              <span class="font-bangers text-xl text-negro tracking-wider">{j.data.precio.toFixed(2)} €</span>
              <a
                href={j.data.amazon}
                target="_blank"
                rel="noopener noreferrer nofollow"
                class="font-fredoka text-xs bg-rojo text-hueso px-3 py-2 border-2 border-negro shadow-comic-sm hover:translate-x-[1px] hover:translate-y-[1px] hover:shadow-none transition-all duration-100 flex items-center gap-1"
                aria-label={`Comprar ${j.data.title} en Amazon`}
              >
                🛒 Comprar
              </a>
            </div>
          </div>
        </article>
      ))}
    </div>
  </SeccionKiosko>

  <Footer slot="footer" />
</Base>
