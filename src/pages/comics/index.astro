---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import TarjetaComic from '../../components/TarjetaComic.astro';
import SeccionKiosko from '../../components/SeccionKiosko.astro';
import { getCollection } from 'astro:content';

const todos = await getCollection('comics');
const clasicos = todos.filter(c => c.data.tipo === 'clasico').sort((a,b) => b.data.fecha.valueOf() - a.data.fecha.valueOf());
const actuales = todos.filter(c => c.data.tipo === 'actual').sort((a,b) => b.data.fecha.valueOf() - a.data.fecha.valueOf());
---

<Base
  title="Cómics — El Kiosko de Siempre"
  description="Catálogo completo de cómics recomendados por Tebeitos: clásicos españoles y novedades actuales para todas las edades."
  breadcrumbs={[{ label: 'Cómics', href: '/comics/' }]}
>
  <Header slot="header" />

  <!-- Breadcrumb -->
  <nav class="contenedor pt-4 pb-2" aria-label="Ruta de navegación">
    <ol class="flex items-center gap-2 font-fredoka text-sm text-negro/70">
      <li><a href="/" class="hover:text-rojo transition-colors">Inicio</a></li>
      <li class="text-trama">›</li>
      <li class="text-negro font-semibold">Cómics</li>
    </ol>
  </nav>

  <!-- Cabecera -->
  <div class="contenedor py-10">
    <h1 class="titulo-seccion text-5xl lg:text-7xl mb-3">📚 Cómics</h1>
    <p class="font-fredoka text-lg text-negro/70 max-w-2xl">
      De ayer y de hoy. Clásicos del kiosko español y novedades que enganchan a los nuevos lectores.
    </p>
  </div>

  <!-- Actuales -->
  <SeccionKiosko titulo="Cómics actuales" fondo="crema" id="actuales">
    <div class="grid-comics">
      {actuales.map(comic => (
        <TarjetaComic
          titulo={comic.data.title}
          slug={comic.slug}
          autor={comic.data.autor}
          edad={comic.data.edad}
          valoracion={comic.data.valoracion}
          precio={comic.data.precio}
          amazon={comic.data.amazon}
          tipo={comic.data.tipo}
        />
      ))}
    </div>
  </SeccionKiosko>

  <!-- Clásicos -->
  <SeccionKiosko titulo="Clásicos del kiosko" fondo="hueso" id="clasicos">
    <div class="grid-comics">
      {clasicos.map(comic => (
        <TarjetaComic
          titulo={comic.data.title}
          slug={comic.slug}
          autor={comic.data.autor}
          edad={comic.data.edad}
          valoracion={comic.data.valoracion}
          precio={comic.data.precio}
          amazon={comic.data.amazon}
          tipo={comic.data.tipo}
        />
      ))}
    </div>
  </SeccionKiosko>

  <Footer slot="footer" />
</Base>
