---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import TarjetaComic from '../../components/TarjetaComic.astro';
import SeccionKiosko from '../../components/SeccionKiosko.astro';
import { getCollection } from 'astro:content';

const todos = await getCollection('comics');
const clasicos = todos.filter(c => c.data.tipo === 'clasico').sort((a,b) => b.data.fecha.valueOf() - a.data.fecha.valueOf());
const actuales = todos.filter(c => c.data.tipo === 'actual').sort((a,b) => b.data.fecha.valueOf() - a.data.fecha.valueOf());
---

<Base
  title="Cómics — El Kiosko de Siempre"
  description="Catálogo completo de cómics recomendados por Tebeitos: clásicos españoles y novedades actuales para todas las edades."
  breadcrumbs={[{ label: 'Cómics', href: '/comics/' }]}
>
  <Header slot="header" />

  <!-- Cabecera de Sección -->
  <section class="trama-bg border-b-4 border-negro pt-6 pb-8">
    <div class="contenedor">
      <h1 class="titulo-seccion text-4xl lg:text-5xl mb-4">Cómics</h1>
      <div class="flex gap-1 mt-2 mb-6">
        <div class="h-1 w-16 bg-rojo"></div>
        <div class="h-1 flex-1 bg-negro"></div>
      </div>
      <p class="font-fredoka text-lg text-negro/70 max-w-3xl">
        De ayer y de hoy. Cómics clásicos españoles de toda la vida y las mejores novedades actuales para todas las edades.
      </p>
    </div>
  </section>

  <!-- Actuales -->
  <SeccionKiosko titulo="Cómics actuales recomendados" fondo="hueso" id="actuales">
    <div class="grid-comics">
      {actuales.map(comic => (
        <TarjetaComic
          titulo={comic.data.title}
          slug={comic.slug}
          autor={comic.data.autor}
          edad={comic.data.edad}
          valoracion={comic.data.valoracion}
          precio={comic.data.precio}
          amazon={comic.data.amazon}
          tipo={comic.data.tipo}
          imagen={comic.data.imagen}
        />
      ))}
    </div>
  </SeccionKiosko>

  <!-- Clásicos -->
  <SeccionKiosko titulo="Cómics clásicos recomendados" fondo="crema" id="clasicos">
    <div class="grid-comics">
      {clasicos.map(comic => (
        <TarjetaComic
          titulo={comic.data.title}
          slug={comic.slug}
          autor={comic.data.autor}
          edad={comic.data.edad}
          valoracion={comic.data.valoracion}
          precio={comic.data.precio}
          amazon={comic.data.amazon}
          tipo={comic.data.tipo}
          imagen={comic.data.imagen}
        />
      ))}
    </div>
  </SeccionKiosko>

  <Footer slot="footer" />
</Base>
