---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import TarjetaComic from '../../components/TarjetaComic.astro';
import SeccionKiosko from '../../components/SeccionKiosko.astro';
import { getCollection } from 'astro:content';

const todos = await getCollection('comics');
const clasicos = todos.filter(c => c.data.tipo === 'clasico').sort((a,b) => b.data.fecha.valueOf() - a.data.fecha.valueOf());
---

<Base
  title="Cómics Clásicos de Siempre — El Kiosko de Siempre"
  description="Catálogo de cómics clásicos españoles seleccionados por Tebeitos: Mortadelo, Zipi y Zape, Astérix y mucho más."
>
  <Header slot="header" />

  <section class="contenedor pt-44 pb-4">
    <h1 class="titulo-seccion text-4xl lg:text-5xl mb-4">Cómics de siempre</h1>
    <div class="flex gap-1 mt-2 mb-6">
      <div class="h-1 w-16 bg-rojo"></div>
      <div class="h-1 flex-1 bg-negro"></div>
    </div>
    <p class="font-fredoka text-lg text-negro/70 mb-10 max-w-3xl">
      Mortadelo, Astérix, Zipi y Zape, Tintín... Los que leía tu padre, los que leías tú, los que leerán tus hijos. Algunos clásicos no caducan. Simplemente esperan.
    </p>
  </section>

  <SeccionKiosko titulo="" fondo="hueso" id="clasicos">
    <div class="grid-comics">
      {clasicos.map(comic => (
        <TarjetaComic
          titulo={comic.data.title}
          slug={comic.slug}
          autor={comic.data.autor}
          edad={comic.data.edad}
          valoracion={comic.data.valoracion}
          precio={comic.data.precio}
          amazon={comic.data.amazon}
          tipo={comic.data.tipo}
          imagen={comic.data.imagen}
        />
      ))}
    </div>
  </SeccionKiosko>

  <Footer slot="footer" />
</Base>
