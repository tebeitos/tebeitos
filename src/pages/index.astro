---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import TarjetaComic from '../components/TarjetaComic.astro';
import SeccionKiosko from '../components/SeccionKiosko.astro';
import Onomatopeya from '../components/Onomatopeya.astro';
import BotonAmazon from '../components/BotonAmazon.astro';
import { getCollection } from 'astro:content';

const todosLosComics = await getCollection('comics');
const destacados = todosLosComics
  .sort((a, b) => b.data.fecha.valueOf() - a.data.fecha.valueOf())
  .slice(0, 8);

// Blog recientes
const todosLosArticulos = await getCollection('blog');
const recientes = todosLosArticulos
  .sort((a, b) => b.data.fecha.valueOf() - a.data.fecha.valueOf())
  .slice(0, 3);

// Secciones del kiosko
const secciones = [
  {
    href: '/comics/',
    icono: '💬',
    titulo: 'Cómics',
    desc: 'De ayer y de hoy. Clásicos del kiosko y novedades de temporada.',
    color: 'bg-mostaza',
  },
  {
    href: '/libros-ilustrados/',
    icono: '🖍️',
    titulo: 'Libros ilustrados',
    desc: 'Arte y cuento en cada página.',
    color: 'bg-trama',
    textColor: 'text-hueso',
  },
  {
    href: '/cromos/',
    icono: '⭐',
    titulo: 'Cromos',
    desc: 'Álbumes Panini, sobres y colecciones para completar.',
    color: 'bg-rojo',
    textColor: 'text-hueso',
  },
  {
    href: '/cartas/',
    icono: '🃏',
    titulo: 'Cartas',
    desc: 'Pokémon, Dragon Ball y todas las cartas coleccionables.',
    color: 'bg-terracota',
    textColor: 'text-hueso',
  },
  {
    href: '/juguetes/',
    icono: '🎮',
    titulo: 'Juguetes retro',
    desc: 'Los juguetes de los 80 y 90 que nunca olvidarás.',
    color: 'bg-negro',
    textColor: 'text-crema',
  },
];
---

<Base
  title="Tebeitos — El Kiosko de Siempre | Cómics, Cromos y Nostalgia"
  description="Tu kiosko online de cómics clásicos y actuales, cromos Panini, cartas y juguetes retro. El kiosko de siempre, ahora en internet."
>
  <Header slot="header" />

  <!-- ============================================================
       BLOQUE 1 — HERO: Esta semana en el kiosko
  ============================================================ -->
  <section class="relative overflow-hidden trama-bg border-b-4 border-negro">
    <div class="absolute inset-0 speed-lines opacity-40 pointer-events-none" aria-hidden="true"></div>

    <div class="contenedor relative z-10 pt-16 pb-16 lg:py-12">
      <div class="flex flex-col lg:flex-row items-center gap-6 lg:gap-16">

        <!-- Texto izquierda -->
        <div class="flex-1 text-center lg:text-left order-2 lg:order-1">

          <h1 class="font-bangers text-5xl lg:text-7xl text-negro leading-none tracking-bangers mb-3"
              style="text-shadow: 3px 3px 0 #E8A01B, 5px 5px 0 #1B1714;">
            MUNDIAL PANINI 2026
          </h1>

          <p class="font-bangers text-2xl lg:text-3xl text-rojo tracking-bangers mb-5">
            980 cromos · 48 selecciones · el más grande de la historia
          </p>

          <p class="font-nunito text-base text-negro/80 mb-8 max-w-lg mx-auto lg:mx-0 leading-relaxed">
            Los quioscos llevan semanas sin stock. Aquí te contamos qué formatos hay,
            cuánto cuesta completarlo de verdad y dónde comprarlo online.
          </p>

          <div class="flex flex-wrap gap-4 justify-center lg:justify-start">
            <a
              href="/cromos/panini-mundial-2026/"
              class="font-bangers text-xl text-hueso bg-rojo px-8 py-3 border-3 border-negro shadow-comic hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-none transition-all duration-100 tracking-bangers"
            >
              VER GUÍA COMPLETA →
            </a>
          </div>
        </div>

        <!-- Cromo Lamine Yamal -->
        <div class="flex-shrink-0 order-1 lg:order-2 relative flex items-center justify-center">

          <!-- El cromo -->
          <div class="relative z-10 mt-8 lg:mt-5" style="transform: rotate(-4deg);">
            <div class="comic-border-lg overflow-hidden shadow-[8px_8px_0px_#1B1714] w-36 sm:w-44 lg:w-52">
              <img
                src="/image/jamine%20lamal.jpg"
                alt="Lamine Yamal — Cromo Panini Mundial 2026"
                width="220"
                height="300"
                class="w-full block"
              />
            </div>
            <!-- Etiqueta "MÁS BUSCADO" -->
            <div class="absolute -top-3 -right-3 bg-rojo border-2 border-negro px-2 py-1 rotate-6 z-20">
              <span class="font-bangers text-xs text-hueso tracking-bangers">⭐ MÁS BUSCADO</span>
            </div>
          </div>

        </div>

      </div>
    </div>
  </section>


  <!-- ============================================================
       BLOQUE 3 — SECCIONES DEL KIOSKO
  ============================================================ -->
  <SeccionKiosko titulo="Las secciones del kiosko" fondo="hueso" id="secciones">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-6">
      {secciones.map(s => (
        <a
          href={s.href}
          class={`comic-border-lg ${s.color} ${s.textColor ?? 'text-negro'} p-6 flex flex-col gap-3 group hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-none transition-all duration-100`}
        >
          <div class="flex items-center gap-4 lg:flex-col lg:items-start lg:gap-2">
            <span class="text-4xl lg:text-5xl">{s.icono}</span>
            <h3 class="font-bangers text-2xl tracking-bangers uppercase leading-tight mt-1 lg:mt-0">
              {s.titulo}
            </h3>
          </div>
          <p class={`font-nunito text-sm leading-snug ${s.textColor ?? 'text-negro/70'}`}>
            {s.desc}
          </p>
          <span class={`font-fredoka text-sm mt-auto group-hover:underline ${s.textColor ?? 'text-negro'}`}>
            Entrar →
          </span>
        </a>
      ))}
    </div>
  </SeccionKiosko>

  <!-- ============================================================
       BLOQUE 4 — CÓMICS DESTACADOS
  ============================================================ -->
  <SeccionKiosko titulo="Esto mola, palabra de Tebeitos" fondo="crema" id="destacados">
    <div class="grid-comics">
      {destacados.map(comic => (
        <TarjetaComic
          titulo={comic.data.title}
          slug={comic.slug}
          autor={comic.data.autor}
          edad={comic.data.edad}
          valoracion={comic.data.valoracion}
          precio={comic.data.precio}
          amazon={comic.data.amazon}
          tipo={comic.data.tipo}
          imagen={comic.data.imagen}
        />
      ))}
    </div>

    <div class="mt-10 text-center">
      <a
        href="/comics/"
        class="font-bangers text-xl text-negro border-3 border-negro px-8 py-3 shadow-comic hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-none transition-all duration-100 inline-block tracking-bangers bg-crema"
      >
        VER TODOS LOS CÓMICS →
      </a>
    </div>
  </SeccionKiosko>

  <!-- ============================================================
       BLOQUE 4 — EN EL KIOSKO ESTA SEMANA
  ============================================================ -->
  <section class="bg-crema border-y-4 border-negro py-12" id="kiosko-semana">
    <div class="contenedor">

      <!-- Título -->
      <div class="flex items-center gap-4 mb-8">
        <h2 class="font-bangers text-4xl lg:text-5xl tracking-bangers text-negro uppercase">
          🔥 Esto hay que probarlo
        </h2>
      </div>

      <!-- JUGUETES CLÁSICOS -->
      <p class="font-fredoka text-xs uppercase tracking-widest text-negro/50 mb-4">🧸 Juguetes retro</p>
      <div class="grid grid-cols-2 sm:grid-cols-4 lg:grid-cols-8 gap-4 mb-10">
        {[
          { titulo: "Cometa Infantil", cover: "/image/covers/cometa.jpg", href: "/juguetes/cometa/", marca: "Generic Classic" },
          { titulo: "Yoyó de Madera", cover: "/image/covers/yoyo.jpg", href: "/juguetes/yoyo/", marca: "Artesanal" },
          { titulo: "Peonza de Madera", cover: "/image/covers/peonza.jpg", href: "/juguetes/peonza/", marca: "Artesanal" },
          { titulo: "Tamagotchi Original", cover: "/image/covers/tamagochi.jpg", href: "/juguetes/tamagochi/", marca: "Bandai" },
          { titulo: "Consola Retro Anbernic", cover: "/image/covers/consola-retro.jpg", href: "/juguetes/consola-retro/", marca: "Anbernic" },
          { titulo: "Cubo de Rubik 3x3", cover: "/image/covers/cubo-rubik.jpg", href: "/juguetes/cubo-rubik/", marca: "Rubik's" },
          { titulo: "Barco Pirata Playmobil", cover: "/image/covers/barco-pirata.jpg", href: "/juguetes/barco-pirata/", marca: "Playmobil" },
          { titulo: "Mano Loca", cover: "/image/covers/mano-loca.jpg", href: "/juguetes/mano-loca/", marca: "Generic Retro" },
        ].map(juguete => (
          <a
            href={juguete.href}
            class="group flex flex-col gap-2"
          >
            <div class="comic-border overflow-hidden bg-hueso aspect-[2/3] relative">
              <img
                src={juguete.cover}
                alt={`Imagen de ${juguete.titulo}`}
                class="w-full h-full object-contain bg-hueso p-1 group-hover:scale-105 transition-transform duration-200"
                loading="lazy"
              />
            </div>
            <p class="font-fredoka text-sm text-negro leading-tight group-hover:text-rojo transition-colors">{juguete.titulo}</p>
            <p class="font-nunito text-xs text-negro/50">{juguete.marca}</p>
          </a>
        ))}
      </div>

    </div>
  </section>

  <!-- ============================================================
       BLOQUE 5 — BANNER NOSTALGIA
  ============================================================ -->
  <section class="bg-mostaza border-y-4 border-negro py-16 relative overflow-hidden">
    <!-- Onomatopeyas decorativas -->
    <div class="absolute top-4 left-8 opacity-30" aria-hidden="true">
      <Onomatopeya texto="¡CHISPUM!" color="terracota" rotacion={-8} />
    </div>
    <div class="absolute bottom-4 right-8 opacity-30" aria-hidden="true">
      <Onomatopeya texto="¡ZAS!" color="rojo" rotacion={12} />
    </div>

    <div class="contenedor text-center relative z-10">
      <p class="font-bangers text-4xl lg:text-6xl text-negro tracking-bangers leading-tight mb-4">
        ¿Recuerdas el kiosko de tu barrio?
      </p>
      <p class="font-bangers text-3xl lg:text-4xl text-negro/70 tracking-bangers mb-2">
        Nosotros tampoco lo hemos olvidado.
      </p>
      <p class="font-nunito text-lg text-negro/80 mb-8 max-w-xl mx-auto">
        Cómics clásicos, cromos, juguetes... todo lo de siempre, con el cariño de siempre.
      </p>
      <a
        href="/comics/de-siempre/"
        class="font-bangers text-xl text-hueso bg-negro px-8 py-3 border-3 border-negro shadow-comic-rojo hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-none transition-all duration-100 inline-block tracking-bangers"
      >
        VER CÓMICS CLÁSICOS →
      </a>
    </div>
  </section>

  <!-- ============================================================
       BLOQUE 6 — ÚLTIMAS DEL BLOG
  ============================================================ -->
  <SeccionKiosko titulo="Del cuaderno de Tebeitos" fondo="hueso" id="blog">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {recientes.map(articulo => {
        const fecha = new Intl.DateTimeFormat('es-ES', {
          day: 'numeric', month: 'short', year: 'numeric'
        }).format(articulo.data.fecha);

        return (
          <article class="comic-border bg-crema flex flex-col group hover:shadow-comic-lg transition-shadow duration-150">
            {articulo.data.imagen ? (
              <div class="h-44 overflow-hidden border-b-3 border-negro bg-crema relative pb-2">
                <img
                  src={articulo.data.imagen}
                  alt={articulo.data.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-200"
                  loading="lazy"
                />
              </div>
            ) : (
              <div class="h-44 bg-trama/50 border-b-3 border-negro flex items-center justify-center">
                <span class="text-4xl">📝</span>
              </div>
            )}

            <div class="p-5 flex flex-col gap-3 flex-1">
              <span class="font-fredoka text-xs text-rojo uppercase tracking-wide">{articulo.data.categoria}</span>

              <h3 class="font-bangers text-xl tracking-bangers text-negro leading-tight group-hover:text-rojo transition-colors line-clamp-2">
                <a href={`/blog/${articulo.slug}/`}>{articulo.data.title}</a>
              </h3>

              <p class="font-nunito text-sm text-negro/70 line-clamp-2 flex-1">
                {articulo.data.descripcion}
              </p>

              <div class="flex items-center justify-between mt-auto pt-3 border-t-2 border-negro/10">
                <span class="font-fredoka text-xs text-trama">{fecha}</span>
                <a
                  href={`/blog/${articulo.slug}/`}
                  class="font-fredoka text-xs text-rojo hover:underline"
                >
                  Leer más →
                </a>
              </div>
            </div>
          </article>
        );
      })}
    </div>

    <div class="mt-10 text-center">
      <a
        href="/blog/"
        class="font-bangers text-xl text-negro border-3 border-negro px-8 py-3 shadow-comic hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-none transition-all duration-100 inline-block tracking-bangers bg-hueso"
      >
        VER TODO EL BLOG →
      </a>
    </div>
  </SeccionKiosko>

  <Footer slot="footer" />
</Base>
