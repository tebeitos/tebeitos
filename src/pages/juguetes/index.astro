---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import TarjetaJuguete from '../../components/TarjetaJuguete.astro';
import SeccionKiosko from '../../components/SeccionKiosko.astro';
import { getCollection } from 'astro:content';

const juguetes = await getCollection('juguetes');
const ordenados = juguetes.sort((a,b) => b.data.fecha.valueOf() - a.data.fecha.valueOf());
---

<Base
  title="Juguetes Retro — El Kiosko de Siempre"
  description="Catálogo completo de juguetes clásicos y nostálgicos recomendados por Tebeitos: yo-yo, peonza, Tamagotchi y más."
  breadcrumbs={[{ label: 'Juguetes', href: '/juguetes/' }]}
>
  <Header slot="header" />

  <!-- Cabecera de Sección -->
  <section class="trama-bg border-b-4 border-negro pt-[4rem] pb-8">
    <div class="contenedor">
      <h1 class="titulo-seccion text-4xl lg:text-5xl mb-4">Juguetes</h1>
      <div class="flex gap-1 mt-2 mb-6">
        <div class="h-1 w-16 bg-rojo"></div>
        <div class="h-1 flex-1 bg-negro"></div>
      </div>
      <p class="font-fredoka text-lg text-negro/70 max-w-3xl">
        El yoyó, la peonza, el Tamagotchi, el Cubo de Rubik... Los juguetes que no necesitaban batería para durar toda la tarde. Algunos han vuelto. Otros nunca se fueron.
      </p>
    </div>
  </section>

  <SeccionKiosko titulo="" fondo="hueso" id="juguetes-lista">

    <div class="grid-comics">
      {ordenados.map(juguete => (
        <TarjetaJuguete
          titulo={juguete.data.title}
          slug={juguete.slug}
          marca={juguete.data.marca}
          edad={juguete.data.edad}
          valoracion={juguete.data.valoracion}
          precio={juguete.data.precio}
          amazon={juguete.data.amazon}
          imagen={juguete.data.imagen}
        />
      ))}
    </div>
  </SeccionKiosko>

  <Footer slot="footer" />
</Base>
