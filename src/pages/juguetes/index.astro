---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import TarjetaJuguete from '../../components/TarjetaJuguete.astro';
import SeccionKiosko from '../../components/SeccionKiosko.astro';
import { getCollection } from 'astro:content';

const juguetes = await getCollection('juguetes');
const ordenados = juguetes.sort((a,b) => b.data.fecha.valueOf() - a.data.fecha.valueOf());
---

<Base
  title="Juguetes Retro — El Kiosko de Siempre"
  description="Catálogo completo de juguetes clásicos y nostálgicos recomendados por Tebeitos: yo-yo, peonza, Tamagotchi y más."
  breadcrumbs={[{ label: 'Juguetes', href: '/juguetes/' }]}
>
  <Header slot="header" />


  <!-- Listado -->
  <SeccionKiosko titulo="Juguetes clásicos recomendados" fondo="crema" id="juguetes-lista">
    <div class="grid-comics">
      {ordenados.map(juguete => (
        <TarjetaJuguete
          titulo={juguete.data.title}
          slug={juguete.slug}
          marca={juguete.data.marca}
          edad={juguete.data.edad}
          valoracion={juguete.data.valoracion}
          precio={juguete.data.precio}
          amazon={juguete.data.amazon}
          imagen={juguete.data.imagen}
        />
      ))}
    </div>
  </SeccionKiosko>

  <Footer slot="footer" />
</Base>
