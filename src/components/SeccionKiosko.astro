---
export interface Props {
  titulo: string;
  fondo?: 'crema' | 'hueso' | 'negro';
  id?: string;
  class?: string;
}

const { titulo, fondo = 'crema', id, class: className = '' } = Astro.props;

const fondos: Record<string, string> = {
  crema: 'bg-crema trama-bg-sutil',
  hueso: 'bg-hueso',
  negro: 'bg-negro text-crema',
};
---

<section
  class={`pt-6 pb-12 md:py-14 ${fondos[fondo]} ${className}`}
  id={id}
>
  <div class="contenedor">
    <!-- Título de sección con decoración cómic -->
    {titulo && (
      <header class="mb-10 flex items-end gap-4">
        <div>
          <h2 class={`titulo-seccion ${fondo === 'negro' ? 'text-crema' : 'text-negro'}`}>
            {titulo}
          </h2>
          <!-- Línea decorativa doble -->
          <div class="flex gap-1 mt-2">
            <div class="h-1 w-16 bg-rojo"></div>
            <div class="h-1 flex-1 bg-negro"></div>
          </div>
        </div>
      </header>
    )}

    <slot />
  </div>
</section>
