---
export interface Props {
  texto: string;
  color?: 'rojo' | 'mostaza' | 'terracota';
  rotacion?: number;
  clase?: string;
}

const {
  texto,
  color = 'rojo',
  rotacion,
  clase = '',
} = Astro.props;

// Si no se pasa rotación, generamos una aleatoria entre -15 y +15
const rot = rotacion ?? Math.floor(Math.random() * 31) - 15;

const colores: Record<string, { bg: string; text: string; border: string }> = {
  rojo:      { bg: '#E1352A', text: '#FBF3E2', border: '#1B1714' },
  mostaza:   { bg: '#E8A01B', text: '#1B1714', border: '#1B1714' },
  terracota: { bg: '#C44B2E', text: '#FBF3E2', border: '#1B1714' },
};

const c = colores[color];
---

<span
  class={`onomatopeya inline-flex items-center justify-center font-bangers text-center leading-none select-none ${clase}`}
  style={`
    transform: rotate(${rot}deg);
    background-color: ${c.bg};
    color: ${c.text};
    border: 3px solid ${c.border};
    clip-path: polygon(
      50% 0%, 61% 15%, 79% 9%, 72% 25%, 90% 26%,
      78% 40%, 93% 50%, 78% 60%, 90% 74%, 72% 75%,
      79% 91%, 61% 85%, 50% 100%, 39% 85%, 21% 91%,
      28% 75%, 10% 74%, 22% 60%, 7% 50%, 22% 40%,
      10% 26%, 28% 25%, 21% 9%, 39% 15%
    );
    padding: 1.5em;
    width: 5.5em;
    height: 5.5em;
    box-shadow: 3px 3px 0 ${c.border};
  `}
  aria-hidden="true"
>
  {texto}
</span>
