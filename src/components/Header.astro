---
const navLinks = [
  {
    label: 'Cómics',
    href: '/comics/',
    dropdown: [
      { href: '/comics/', label: 'Ver todos los cómics' },
      { href: '/libros-ilustrados/', label: 'Libros ilustrados' }
    ]
  },
  { href: '/cromos/', label: 'Cromos' },
  { href: '/cartas/', label: 'Cartas' },
  { href: '/juguetes/', label: 'Juguetes' },
  { href: '/blog/', label: 'Blog' },
];

const currentPath = Astro.url.pathname;
---

<header class="bg-crema border-b-[3px] border-negro sticky top-0 z-50">
  <div class="contenedor flex items-center justify-between py-5 gap-4">

    <!-- Logo -->
    <a href="/" class="flex items-center group flex-shrink-0" aria-label="Tebeitos — Inicio">
      <img
        src="/image/A _ Principal horizontal.png"
        alt="Tebeitos — El Kiosko de Siempre"
        class="h-24 w-auto group-hover:opacity-90 transition-opacity duration-150"
      />
    </a>

    <!-- Nav desktop -->
    <nav class="hidden md:flex items-center gap-1" aria-label="Navegación principal">
      {navLinks.map(link => (
        link.dropdown ? (
          <div class="relative group">
            <button
              class={`font-fredoka text-sm px-3 py-2 border-2 transition-all duration-150 flex items-center gap-1 hover:bg-negro hover:text-crema border-transparent text-negro hover:border-negro
                ${currentPath.startsWith(link.href) || currentPath.startsWith('/libros-ilustrados/')
                  ? 'bg-negro text-crema border-negro'
                  : ''
                }`}
            >
              {link.label}
              <span class="text-xs transition-transform group-hover:rotate-180">▼</span>
            </button>
            <div class="absolute left-0 mt-1 hidden group-hover:block bg-crema border-3 border-negro shadow-comic min-w-[220px] z-50">
              {link.dropdown.map(sub => (
                <a
                  href={sub.href}
                  class={`block font-fredoka text-sm px-4 py-3 hover:bg-negro hover:text-crema border-b border-negro/10 last:border-b-0
                    ${currentPath === sub.href ? 'bg-negro/5 text-negro font-semibold' : 'text-negro'}`}
                >
                  {sub.label}
                </a>
              ))}
            </div>
          </div>
        ) : (
          <a
            href={link.href}
            class={`font-fredoka text-sm px-3 py-2 border-2 transition-all duration-150 hover:bg-negro hover:text-crema
              ${currentPath.startsWith(link.href)
                ? 'bg-negro text-crema border-negro'
                : 'border-transparent text-negro hover:border-negro'
              }`}
          >
            {link.label}
          </a>
        )
      ))}
    </nav>

    <!-- Hamburger mobile -->
    <button
      id="menu-toggle"
      class="md:hidden flex flex-col gap-1.5 p-2 border-2 border-negro bg-mostaza hover:bg-rojo hover:text-hueso transition-colors"
      aria-label="Abrir menú"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span class="block w-5 h-0.5 bg-negro"></span>
      <span class="block w-5 h-0.5 bg-negro"></span>
      <span class="block w-5 h-0.5 bg-negro"></span>
    </button>
  </div>

  <!-- Menú móvil -->
  <div
    id="mobile-menu"
    class="md:hidden hidden bg-crema border-t-4 border-negro"
    aria-hidden="true"
  >
    <nav class="contenedor py-4 flex flex-col gap-1" aria-label="Menú móvil">
      {navLinks.map(link => (
        link.dropdown ? (
          <div class="flex flex-col border-2 border-negro bg-hueso mb-1">
            <span class="font-fredoka text-base px-4 py-3 bg-negro text-crema font-bold border-b border-negro">
              {link.label}
            </span>
            <div class="flex flex-col">
              {link.dropdown.map(sub => (
                <a
                  href={sub.href}
                  class={`font-fredoka text-sm px-6 py-3 border-b border-negro/10 last:border-b-0 transition-colors hover:bg-negro hover:text-crema
                    ${currentPath === sub.href ? 'bg-negro/5 text-negro font-semibold' : 'text-negro'}`}
                >
                  {sub.label}
                </a>
              ))}
            </div>
          </div>
        ) : (
          <a
            href={link.href}
            class={`font-fredoka text-base px-4 py-3 border-2 border-negro transition-colors hover:bg-negro hover:text-crema
              ${currentPath.startsWith(link.href) ? 'bg-negro text-crema' : 'bg-hueso text-negro'}`}
          >
            {link.label}
          </a>
        )
      ))}
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu   = document.getElementById('mobile-menu');

  toggle?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    toggle.setAttribute('aria-expanded', String(!isOpen));
    menu?.setAttribute('aria-hidden', String(isOpen));
  });

  // Cerrar menú al hacer clic en un enlace
  menu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      menu.classList.add('hidden');
      toggle?.setAttribute('aria-expanded', 'false');
      menu.setAttribute('aria-hidden', 'true');
    });
  });
</script>
