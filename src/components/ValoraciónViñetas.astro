---
export interface Props {
  valoracion: number; // 1-5
}

const { valoracion } = Astro.props;
---

<div
  class="flex items-center gap-1"
  aria-label={`Valoración: ${valoracion} de 5`}
  role="img"
>
  {Array.from({ length: 5 }).map((_, i) => (
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 32 32"
      width="24"
      height="24"
      aria-hidden="true"
      class={i < valoracion ? 'drop-shadow-sm' : 'opacity-30'}
    >
      <!-- Bocadillo de cómic redondeado -->
      <path
        d={`M4 4 Q4 2 6 2 L26 2 Q28 2 28 4 L28 20 Q28 22 26 22 L18 22 L14 30 L12 22 L6 22 Q4 22 4 20 Z`}
        fill={i < valoracion ? '#E8A01B' : '#CBB892'}
        stroke="#1B1714"
        stroke-width="2"
      />
    </svg>
  ))}
  <span class="font-fredoka text-sm text-negro/70 ml-1">({valoracion}/5)</span>
</div>
