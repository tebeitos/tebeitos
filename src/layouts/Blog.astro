---
import Base from './Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

export interface Props {
  title: string;
  descripcion: string;
  fecha: Date;
  categoria: string;
  imagen?: string;
}

const { title, descripcion, fecha, categoria, imagen } = Astro.props;

const fechaFormateada = new Intl.DateTimeFormat('es-ES', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
}).format(fecha);

const breadcrumbs = [
  { label: 'Blog', href: '/blog/' },
  { label: title, href: '' },
];
---

<Base title={title} description={descripcion} breadcrumbs={breadcrumbs}>
  <Header slot="header" />

  <!-- Cabecera del artículo -->
  <header class="contenedor pt-36 pb-10">
    <span class="inline-block bg-mostaza text-negro font-fredoka text-xs px-3 py-1 border-2 border-negro mb-4 uppercase">
      {categoria}
    </span>
    <h1 class="titulo-seccion text-4xl lg:text-5xl mb-4 max-w-3xl">{title}</h1>
    <p class="font-nunito text-lg text-negro/70 mb-6 max-w-2xl">{descripcion}</p>

    {imagen && (
      <div class="comic-border-lg max-w-3xl overflow-hidden mb-6 bg-crema">
        <img
          src={imagen}
          alt={`Imagen ilustrativa de ${title}`}
          class="w-full h-auto max-h-[380px] object-cover block"
        />
      </div>
    )}

    <p class="font-fredoka text-sm text-trama">
      📅 {fechaFormateada} · Tebeitos
    </p>
    <div class="mt-6 border-t-4 border-negro"></div>
  </header>

  <!-- Cuerpo MDX -->
  <article class="contenedor pb-16">
    <div class="max-w-3xl prose-tebeitos">
      <slot />
    </div>
  </article>

  <Footer slot="footer" />
</Base>
